{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Pylon",
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo.svg",
    "dark": "/logo.svg"
  },
  "colors": {
    "primary": "#89B4FA",
    "light": "#EEF0FE",
    "dark": "#1A1D3A"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/pylonto/pylon"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "installation"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/pylons",
              "concepts/nexus",
              "concepts/triggers",
              "concepts/agents",
              "concepts/channels",
              "concepts/workspaces"
            ]
          },
          {
            "group": "YAML",
            "pages": [
              "yaml/pylon",
              "yaml/config"
            ]
          },
          {
            "group": "Examples",
            "pages": [
              "examples/webhooks",
              "examples/cron"
            ]
          },
          {
            "group": "Running",
            "pages": [
              "running/daemon",
              "running/troubleshooting"
            ]
          }
        ]
      },
      {
        "tab": "CLI",
        "groups": [
          {
            "group": "Commands",
            "pages": [
              "cli/setup",
              "cli/construct",
              "cli/nexus",
              "cli/start",
              "cli/list",
              "cli/jobs",
              "cli/doctor",
              "cli/upgrade"
            ]
          }
        ]
      }
    ]
  }
}
