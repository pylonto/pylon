  "keyFeatures": [
    "Event-driven pipelines (webhook and cron triggers)",
    "Sandboxed AI agents running in Docker containers",
    "Human-in-the-loop approval via Telegram or Slack before agent runs",
    "Built-in support for Claude Code and OpenCode agents",
    "Git workspace modes: fresh clone, worktree, or local path",
    "Pipeline templates for Sentry triage, GitHub PR review, and cron audits",
    "Go template-based prompt injection from webhook payloads",
    "Per-pylon job history and logs",
    "Host tool bridge for agents to call host CLIs",
    "systemd service integration for always-on daemon"
  ],
  "publicApiSurface": [
    "pylon setup",
    "pylon construct <name> [--from template]",
    "pylon start [name]",
    "pylon stop",
    "pylon restart",
    "pylon list",
    "pylon edit <name>",
    "pylon test <name> [--payload JSON]",
    "pylon destroy <name>",
    "pylon jobs [pylon-name]",
    "pylon logs <job-id>",
    "pylon attach <job-id>",
    "pylon kill <job-id>",
    "pylon retry <job-id>",
    "pylon doctor",
    "pylon upgrade",
    "pylon service install",
    "pylon service uninstall",
    "pylon service status",
    "pylon completion [bash|zsh|fish]",
    "pylon version",
    "Webhook HTTP endpoint: POST /<pylon-path>",
    "~/.pylon/config.yaml (global config)",
    "~/.pylon/pylons/<name>/pylon.yaml (per-pylon config)",
    "~/.pylon/.env (secrets store)"
  ]
}
