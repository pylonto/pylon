{
  "projectType": "cli-tool",
  "projectName": "Pylon",
  "projectDescription": "A self-hosted daemon that listens for webhook and cron events, spins up sandboxed AI coding agents in Docker containers, and reports results back to Telegram or Slack.",
  "theme": "aspen",
